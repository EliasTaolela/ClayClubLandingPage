@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<section class="section-subscribe grainy" style="min-height:100vh;display:flex;align-items:center;justify-content:center;">
    
    <div class="ghost-bg" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:clamp(6rem,16vw,15rem);opacity:0.05;">
        LOGIN
    </div>

    <div class="subscribe-inner" style="max-width:500px;width:100%;">

        <p class="section-label">✦ Welcome Back</p>

        <h2 class="section-title">
            LOGIN<br>
            <span style="-webkit-text-stroke:3px var(--ink);color:transparent;">
                TO CLAY
            </span>
        </h2>

        <p style="margin-bottom:2rem;">
            Enter your details and get back into the studio.
        </p>

        <!-- 🔥 FORM -->
        <form method="post" class="subscribe-form" style="flex-direction:column;gap:1rem;">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- EMAIL -->
            <input asp-for="Input.Email" placeholder="your@email.com" autocomplete="username" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>

            <!-- PASSWORD -->
            <input asp-for="Input.Password" type="password" placeholder="Password" autocomplete="current-password" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>

            <!-- REMEMBER ME -->
            <div style="display:flex;align-items:center;gap:10px;">
                <input asp-for="Input.RememberMe" />
                <label asp-for="Input.RememberMe">Remember me</label>
            </div>

            <!-- SUBMIT -->
            <button type="submit" class="btn-primary">
                Login →
            </button>

        </form>

        <!-- LINKS -->
        <div style="margin-top:1.5rem;">
            <p>
                Don’t have an account?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register</a>
            </p>

            <p>
                <a asp-page="./ForgotPassword">Forgot your password?</a>
            </p>
        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}